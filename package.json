{
  "name": "raster",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:plugin": "pnpm --dir packages/unplugin-raster test",
    "build:runtime": "pnpm --dir packages/raster build:runtime",
    "build:template": "pnpm --dir apps/template build",
    "docs:dev": "pnpm --dir docs dev",
    "docs:build": "pnpm --dir docs build",
    "docs:preview": "pnpm --dir docs preview",
    "build": "pnpm run typecheck && pnpm run build:runtime && pnpm run build:template"
  },
  "devDependencies": {
    "@types/react": "19.2.15",
    "@types/react-reconciler": "0.33.0",
    "esbuild": "0.28.0",
    "typescript": "6.0.3"
  }
}
