{
  "name": "raster",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:plugin": "pnpm --dir packages/unplugin-raster test",
    "docs:dev": "pnpm --dir docs dev",
    "docs:preview": "pnpm --dir docs preview",
    "build:js": "pnpm run typecheck && pnpm run build:runtime && pnpm run build:plugin && pnpm run build:template",
    "build:runtime": "pnpm --dir packages/raster build:runtime",
    "build:plugin": "pnpm --dir packages/unplugin-raster build",
    "build:template": "pnpm --dir apps/showcase build",
    "build:platforms": "node scripts/build.mjs",
    "build": "pnpm build:js && pnpm build:platforms",
    "build:android": "node scripts/build.mjs --platform android-arm64",
    "build:ios": "node scripts/build.mjs --platform ios-xcframework",
    "docs:build": "pnpm --dir docs build",
    "pack:ios:spm": "node scripts/build.mjs --platform ios-xcframework",
    "dev:ios": "pnpm --dir packages/cli exec raster dev ios",
    "dev:debug": "pnpm --dir apps/debug dev",
    "debug:ios:runtime": "node scripts/build.mjs --platform ios-xcframework",
    "debug:ios:dev": "pnpm --dir apps/debug dev:ios",
    "debug:android:dev": "pnpm --dir apps/debug dev:android",
    "publish:android:local": "ANDROID_HOME=${ANDROID_HOME:-$HOME/Library/Android/sdk} ANDROID_SDK_ROOT=${ANDROID_SDK_ROOT:-$HOME/Library/Android/sdk} gradle -p packages/raster-android :raster-android:publishReleasePublicationToMavenLocal",
    "publish:android:staging": "ANDROID_HOME=${ANDROID_HOME:-$HOME/Library/Android/sdk} ANDROID_SDK_ROOT=${ANDROID_SDK_ROOT:-$HOME/Library/Android/sdk} gradle -p packages/raster-android :raster-android:publishReleasePublicationToLocalStagingRepository",
    "pack:android:maven": "rm -rf packages/raster-android/build/maven-staging packages/raster-android/build/raster-android-maven-central-bundle.zip && pnpm run publish:android:staging && cd packages/raster-android/build/maven-staging && zip -qr ../raster-android-maven-central-bundle.zip .",
    "publish:android:maven": "node scripts/publish-maven-central.mjs",
    "release": "pnpm run release:js",
    "release:js": "node scripts/release.mjs js",
    "release:bin": "node scripts/release.mjs bin",
    "release:all": "node scripts/release.mjs all",
    "release:js:dry-run": "node scripts/release.mjs js --dry-run",
    "release:bin:dry-run": "node scripts/release.mjs bin --dry-run",
    "release:all:dry-run": "node scripts/release.mjs all --dry-run"
  },
  "devDependencies": {
    "@types/react": "19.2.15",
    "@types/react-reconciler": "0.33.0",
    "esbuild": "0.28.0",
    "typescript": "6.0.3"
  }
}
