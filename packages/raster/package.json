{
  "name": "raster-js",
  "version": "0.1.0-alpha.12",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    },
    "./component": {
      "types": "./dist/component/index.d.ts",
      "default": "./dist/component/index.js"
    },
    "./components": {
      "types": "./dist/component/index.d.ts",
      "default": "./dist/component/index.js"
    },
    "./bridge": {
      "types": "./dist/bridge/index.d.ts",
      "default": "./dist/bridge/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"import('node:fs/promises').then(async fs => { await fs.mkdir('dist/core', { recursive: true }); await fs.copyFile('src/core/jsx.d.ts', 'dist/core/jsx.d.ts'); })\"",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:runtime": "node ../../scripts/build-runtime.mjs"
  },
  "dependencies": {
    "react": "19.2.6",
    "react-reconciler": "0.33.0"
  },
  "devDependencies": {
    "@types/react": "19.2.15",
    "@types/react-reconciler": "0.33.0",
    "esbuild": "0.28.0",
    "typescript": "6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
