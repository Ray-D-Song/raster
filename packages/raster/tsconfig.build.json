  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "rewriteRelativeImportExtensions": true
  },
  "include": [
    "src/component/**/*.ts",
    "src/core/**/*.ts",
    "src/react/index.ts"
  ]
}
